# Copy to `.env`.
#
# PRODUCTION path — deployed Cloudflare Worker (key stays server-side):
EXPO_PUBLIC_PARSER_URL=https://aahaar-parser.your-subdomain.workers.dev
#
# DEV path A — local Ollama: UNLIMITED, free, private (no rate limits). Best for dev.
#   1. Install Ollama (https://ollama.com/download), then: ollama pull llama3.1
#      (low RAM? use a smaller model: ollama pull llama3.2:3b)
#   2. Make it reachable off-localhost: set OLLAMA_HOST=0.0.0.0 and restart Ollama;
#      allow port 11434 through Windows Firewall.
#   3. Set the URL below:
#        Android emulator → host machine:  http://10.0.2.2:11434
#        Physical iPhone (same Wi-Fi)    → http://<your-PC-LAN-IP>:11434
# EXPO_PUBLIC_OLLAMA_URL=http://10.0.2.2:11434
# EXPO_PUBLIC_OLLAMA_MODEL=llama3.1

# DEV path B — call Groq directly (rate-limited free tier).
# ⚠️ This key is bundled into the app JS; use ONLY for local dev, never ship it.
# Get a free key at https://console.groq.com → API Keys.
# EXPO_PUBLIC_GROQ_KEY=gsk_your_dev_key_here
# EXPO_PUBLIC_GROQ_MODEL=llama-3.3-70b-versatile

# DEV path C — any OpenAI-compatible endpoint (free gateways; key often optional).
# Recommended: llm7.io — no signup, ~150 req/min (higher than Groq's 30/min).
#   EXPO_PUBLIC_OPENAI_BASE_URL=https://api.llm7.io/v1
#   EXPO_PUBLIC_OPENAI_MODEL=gpt-5.4-mini    # any id from https://api.llm7.io/v1/models
#   EXPO_PUBLIC_OPENAI_KEY=                   # leave blank for llm7.io; set if a gateway needs one
# Other OpenAI-compatible options: g4f.dev, uncloseai.com (set BASE_URL + MODEL accordingly).
# ⚠️ Any key here is bundled into the app JS — dev only; never ship it.

# Provider preference when several are set: Worker → Ollama → Groq → OpenAI-compat → offline.
# All AI parses are cached locally, so repeated meals never re-hit the model.
